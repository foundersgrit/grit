rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 1. DEFAULT DENY
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isUnderSizeLimit() {
       // Enforce 5MB limit
       return request.resource.size < 5 * 1024 * 1024;
    }

    // Profiles (Avatars): Owner write, Public read
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isUnderSizeLimit();
    }
    
    // Product Images: Admin write, Public read
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Repair/Support uploads: Owner write/read, Admin read
    match /support/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isUnderSizeLimit();
    }
  }
}
